{
  // Code Runner: compila con warnings y ejecuta en la terminal integrada.
  // runInTerminal=true es CLAVE: sin esto, scanf no puede leer lo que escribis.
  "code-runner.executorMap": {
    "c": "cd $dir && gcc -Wall -Wextra -std=c11 \"$fileName\" -o \"$fileNameWithoutExt\" && \"$dir$fileNameWithoutExt\""
  },
  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.clearPreviousOutput": true,
  "C_Cpp.default.cStandard": "c11",
  "files.encoding": "utf8",

  // === Formateo automatico (clang-format, el "prettier" de C) ===
  // Al guardar, ordena indentacion y llaves segun el archivo .clang-format.
  "editor.formatOnSave": true,
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },

  // === Linter extra mientras escribis (sugerencias de estilo y posibles bugs) ===
  "C_Cpp.codeAnalysis.clangTidy.enabled": true,
  "C_Cpp.codeAnalysis.runAutomatically": true,

  // === Error Lens: muestra el error/warning al lado de la linea ===
  "errorLens.enabled": true,
  "errorLens.enabledDiagnosticLevels": ["error", "warning", "info"]
}
